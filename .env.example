# Copy this file's contents into Vercel's Environment Variables dashboard.
# Never commit a real .env file to git — .gitignore already excludes it.

# Required. Your real Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- Licensing (Free/Pro plans) ---
# Requires connecting Vercel KV to this project (Vercel dashboard →
# Storage → Create Database → KV). Once connected, Vercel sets
# KV_REST_API_URL and KV_REST_API_TOKEN for you automatically — you
# don't need to fill those in by hand.

# Optional. How many reports a Free-plan license gets per calendar month.
# Defaults to 20 if not set (see FREE_MONTHLY_LIMIT in api/_lib/licensing.js).
FREE_MONTHLY_LIMIT=20

# --- Payment provider ---
# Which adapter in api/_lib/providers/ is active. Only "lemonsqueezy" is
# actually implemented right now; "paddle" is a documented stub. See
# api/_lib/providers/index.js for the full swap-a-provider contract.
PAYMENT_PROVIDER=lemonsqueezy

# Required for Lemon Squeezy. Get these from your Lemon Squeezy dashboard:
# Settings → API (for the API key), the store's own settings page (for the
# store ID), and the Pro subscription product's variant page (for the
# variant ID) — https://app.lemonsqueezy.com
LEMONSQUEEZY_API_KEY=...
LEMONSQUEEZY_STORE_ID=...
LEMONSQUEEZY_PRO_VARIANT_ID=...

# Required for Lemon Squeezy webhooks. Lemon Squeezy doesn't generate this
# for you — pick any random string yourself (between 6 and 40 characters),
# enter the SAME value when creating the webhook in Settings → Webhooks
# (pointed at https://yourdomain.com/api/payment-webhook, subscribed to at
# minimum: subscription_created, subscription_payment_success,
# subscription_cancelled, subscription_expired), and set it here too.
LEMONSQUEEZY_WEBHOOK_SECRET=choose-a-random-string-here

# Required (used to build the redirect URLs Lemon Squeezy sends the
# browser back to after checkout). Your deployed site's base URL, no
# trailing slash.
SITE_URL=https://kidbuster.vercel.app

# Required for the feedback feature (api/feedback.js). The URL you get after
# deploying google-apps-script.js as a Web App from your Google Sheet.
# Without this, star-rating feedback on generated reports has nowhere to go.
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
